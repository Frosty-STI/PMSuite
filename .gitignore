# user data (never committed)
projects/
projects/.backups/

# build artifacts (keep the empty directory tracked via .gitkeep)
output/*
!output/.gitkeep

# Streamlit local state
.streamlit/recents.json
.streamlit/secrets.toml

# logs (always on)
.logs/

# Python build/cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/
.venv/
venv/
.env

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
